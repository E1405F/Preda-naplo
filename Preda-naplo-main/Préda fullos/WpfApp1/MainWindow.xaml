<!-- MainWindow.xaml -->
<Window x:Class="PredaNaplo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Préda Napló - Digitális Iskola Napló" Height="650" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#79AE6F">
    
    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="PrimaryColor"   Color="#4A2C0A"/>
        <SolidColorBrush x:Key="SecondaryColor" Color="#5C8A3C"/>
        <SolidColorBrush x:Key="SuccessColor"   Color="#3A7A2A"/>
        <SolidColorBrush x:Key="WarningColor"   Color="#A0520A"/>
        <SolidColorBrush x:Key="DangerColor"    Color="#8B1A1A"/>
        <SolidColorBrush x:Key="TextColor"      Color="#3B1A00"/>
        <SolidColorBrush x:Key="CardColor"      Color="#EAF5E6"/>
        <SolidColorBrush x:Key="BorderColor"    Color="#A8C898"/>

        <DropShadowEffect x:Key="DropShadow" BlurRadius="10" Opacity="0.18" ShadowDepth="2"/>

        <!-- Modern Button -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource SecondaryColor}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontSize"     Value="14"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Padding"      Value="20,10"/>
            <Setter Property="Margin"       Value="5"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A7230"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource DangerColor}"/>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource SuccessColor}"/>
        </Style>

        <!-- TextBox -->
        <Style x:Key="ModernTextBox" TargetType="TextBox">
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Padding"         Value="10"/>
            <Setter Property="Margin"          Value="5"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background"      Value="#F5FBF3"/>
            <Setter Property="Foreground"      Value="{StaticResource TextColor}"/>
        </Style>

        <!-- PasswordBox -->
        <Style x:Key="ModernPasswordBox" TargetType="PasswordBox">
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Padding"         Value="10"/>
            <Setter Property="Margin"          Value="5"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background"      Value="#F5FBF3"/>
            <Setter Property="Foreground"      Value="{StaticResource TextColor}"/>
        </Style>

        <!-- ListBox -->
        <Style x:Key="ModernListBox" TargetType="ListBox">
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="Background"      Value="{StaticResource CardColor}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground"      Value="{StaticResource TextColor}"/>
        </Style>

        <!-- DataGrid -->
        <Style x:Key="ModernDataGrid" TargetType="DataGrid">
            <Setter Property="FontSize"               Value="12"/>
            <Setter Property="Background"             Value="{StaticResource CardColor}"/>
            <Setter Property="AlternatingRowBackground" Value="#DFF0D8"/>
            <Setter Property="GridLinesVisibility"    Value="Horizontal"/>
            <Setter Property="BorderBrush"            Value="{StaticResource BorderColor}"/>
            <Setter Property="BorderThickness"        Value="1"/>
            <Setter Property="Foreground"             Value="{StaticResource TextColor}"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource PrimaryColor}" Padding="20,15">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="📚" FontSize="28" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="Préda Napló" FontSize="24" FontWeight="Bold" Foreground="White" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Digitális Iskola Napló" FontSize="14" Foreground="#C8A878" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="UserInfoText" FontSize="14" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <Button x:Name="LogoutButton" Content="Kijelentkezés"
                            Background="#79AE6F" Foreground="White"
                            BorderThickness="0" Padding="15,8" Cursor="Hand"
                            Click="LogoutButton_Click" Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="20">

            <!-- Login Panel -->
            <Grid x:Name="LoginPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                <Border Background="{StaticResource CardColor}" CornerRadius="10" Padding="30"
                        Effect="{StaticResource DropShadow}"
                        BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Bejelentkezés" FontSize="24" FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryColor}"
                                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

                        <TextBlock Text="Felhasználónév" Margin="0,10,0,5" Foreground="{StaticResource TextColor}"/>
                        <TextBox x:Name="LoginUsername" Style="{StaticResource ModernTextBox}"/>

                        <TextBlock Text="Jelszó" Margin="0,10,0,5" Foreground="{StaticResource TextColor}"/>
                        <PasswordBox x:Name="LoginPassword" Style="{StaticResource ModernPasswordBox}"/>

                        <Button Content="Bejelentkezés" Style="{StaticResource ModernButton}"
                                Click="LoginButton_Click" Margin="0,20,0,0"/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                            <Button Content="Regisztráció" Style="{StaticResource ModernButton}"
                                    Background="#7A5C30"
                                    Click="RegisterButton_Click" Width="120"/>
                            <Button Content="Elfelejtett jelszó" Style="{StaticResource ModernButton}"
                                    Background="#7A5C30"
                                    Click="ForgotPasswordButton_Click" Width="145" Height="40" Margin="10,0,0,0"/>
                        </StackPanel>

                        <TextBlock x:Name="LoginMessage" Foreground="{StaticResource DangerColor}"
                                   TextAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Main Application Panel -->
            <Grid x:Name="MainPanel" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" Background="{StaticResource CardColor}" CornerRadius="10"
                        Margin="0,0,10,0" Padding="10"
                        BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
                    <StackPanel>
                        <Border Background="{StaticResource PrimaryColor}" CornerRadius="5"
                                Padding="15" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock x:Name="UserRoleText" FontSize="12" Foreground="#C8A878" TextAlignment="Center"/>
                                <TextBlock x:Name="UserNameText" FontSize="16" FontWeight="Bold" Foreground="White"
                                           TextAlignment="Center" Margin="0,5,0,0"/>
                                <TextBlock x:Name="UserSchoolText" FontSize="12" Foreground="#C8A878"
                                           TextAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <ListBox x:Name="MenuListBox" Background="Transparent" BorderThickness="0"
                                 SelectionChanged="MenuListBox_SelectionChanged" FontSize="14"
                                 Foreground="{StaticResource TextColor}">
                            <ListBoxItem Content="📖 Jegyek megtekintése"    Tag="Grades"/>
                            <ListBoxItem Content="📝 Jegyek kezelése"        Tag="GradeManagement" Visibility="Collapsed"/>
                            <ListBoxItem Content="📊 Statisztikák"           Tag="Statistics"      Visibility="Collapsed"/>
                            <ListBoxItem Content="👥 Felhasználók kezelése"  Tag="UserManagement"  Visibility="Collapsed"/>
                            <ListBoxItem Content="📢 Közlemények"            Tag="Announcements"/>
                            <ListBoxItem Content="📅 Hiányzások"             Tag="Absences"/>
                            <ListBoxItem Content="📢 Fellebbezés benyújtása" Tag="Appeal" Visibility="Collapsed"/>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- Content Area -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ContentPanel" Margin="10,0,0,0"/>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
