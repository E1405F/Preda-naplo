<Window x:Class="PredaNaplo.JelszoValtoztatasDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Jelszó változtatás"
        Width="350" Height="Auto"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Background="#D6EDD0">
    <StackPanel Margin="20">
        <TextBlock Text="Új jelszó:" Margin="0,0,0,5" FontSize="14"
                   Foreground="#3B1A00" FontWeight="SemiBold"/>
        <PasswordBox x:Name="NewPasswordBox"
                     FontSize="14"
                     Padding="8"
                     Margin="0,0,0,20"
                     BorderBrush="#A8C898"
                     BorderThickness="1"
                     Background="#F5FBF3"
                     Foreground="#3B1A00"/>
        <Button Content="Módosítás"
                Background="#5C8A3C"
                Foreground="White"
                FontSize="14"
                FontWeight="SemiBold"
                Padding="12,8"
                Cursor="Hand"
                BorderThickness="0"
                Width="110"
                HorizontalAlignment="Center"
                Click="SaveButton_Click"/>
    </StackPanel>
</Window>
